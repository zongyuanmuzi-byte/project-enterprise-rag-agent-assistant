# =========================
# App
# =========================
APP_NAME=Enterprise RAG Agent Assistant
APP_ENV=development
DATABASE_URL=sqlite:///./data/app.db
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# =========================
# LLM
# =========================
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_API_KEY=your_deepseek_api_key
LLM_TIMEOUT_SECONDS=60

# =========================
# Embedding
# =========================
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
EMBEDDING_MODEL=embedding-3
EMBEDDING_API_KEY=your_zhipu_api_key
EMBEDDING_TIMEOUT_SECONDS=30

# =========================
# RAG - Text Split
# =========================
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# =========================
# RAG - Retrieval
# =========================
TOP_K=3
MIN_RELEVANCE_SCORE=0.2

# =========================
# Storage local mode
# =========================
STORAGE_PROVIDER=local
UPLOAD_DIR=./data/uploads

# =========================
# Tencent COS mode
# =========================
# STORAGE_PROVIDER=cos
# COS_SECRET_ID=your_cos_secret_id
# COS_SECRET_KEY=your_cos_secret_key
# COS_BUCKET=your_bucket_name
# COS_REGION=ap-guangzhou
# COS_PREFIX=uploads/

# =========================
# Vector store local mode
# =========================
VECTOR_STORE_PROVIDER=chroma
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=enterprise_knowledge_base

# =========================
# Tencent VectorDB mode
# =========================
# VECTOR_STORE_PROVIDER=tencent_vectordb
# TENCENT_VECTORDB_URL=
# TENCENT_VECTORDB_API_KEY=
# TENCENT_VECTORDB_USERNAME=
# TENCENT_VECTORDB_PASSWORD=
# TENCENT_VECTORDB_DATABASE=
# TENCENT_VECTORDB_COLLECTION=enterprise_rag_chunks
# TENCENT_VECTORDB_DIMENSION=2048
